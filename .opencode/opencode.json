{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "read": "allow",
    "grep": "allow",
    "glob": "allow",
    "list": "allow",
    "skill": {
      "*": "allow"
    },
    "edit": "ask",
    "bash": "ask",
    "webfetch": "ask",
    "websearch": "ask",
    "question": "allow",
    "update-mental-model": "allow"
  },
  "mcp": {
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp",
        "--api-key",
        "{env:CONTEXT7_API_KEY}"
      ],
      "enabled": true,
      "timeout": 60000
    },
    "brave-search": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@brave/brave-search-mcp-server"
      ],
      "environment": {
        "BRAVE_API_KEY": "{env:BRAVE_API_KEY}"
      },
      "enabled": true,
      "timeout": 60000
    },
    "firecrawl": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "firecrawl-mcp"
      ],
      "environment": {
        "FIRECRAWL_API_KEY": "{env:FIRECRAWL_API_KEY}"
      },
      "enabled": true,
      "timeout": 120000
    },
    "zeplin": {
      "enabled": true,
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@zeplin/mcp-server@latest"
      ],
      "environment": {
        "ZEPLIN_ACCESS_TOKEN": "{env:ZEPLIN_ACCESS_TOKEN}"
      }
    }
  }
}
