# ─────────────────────────────────────────────
#  Pi Agent — Provider API Keys Sample
#  Copy to .env and fill in your keys
#  Auto-loaded from multi-agents/.env by multi-team.ts and mcp-bridge.ts
#  Optional override: PI_ENV_FILE=relative/path/to/.env
# ─────────────────────────────────────────────

# OpenAI
OPENAI_API_KEY=sk-...

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini
GEMINI_API_KEY=AIza...

# OpenRouter
OPENROUTER_API_KEY=sk-or-...

# Firecrawl
FIRECRAWL_API_KEY=fc-...

# Brave Search MCP
BRAVE_API_KEY=BSA...
